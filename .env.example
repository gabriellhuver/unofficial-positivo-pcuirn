# Server
PORT=3000

# Positivo Casa Inteligente account (same credentials as the mobile app)
POSITIVO_EMAIL=you@example.com
POSITIVO_PASSWORD=your_password

# Optional: force a fresh login instead of reusing storage/session.json
# POSITIVO_FORCE_LOGIN=1

# Optional: refresh devices.json on every API call instead of using cache
# POSITIVO_REFRESH_DEVICES=1

# PCUIRN gateway — run `node positivo.js` to discover these values
DEVICE_ID=your_gateway_device_id
DEVICE_LOCAL_KEY=your_local_key
DEVICE_IP=192.168.x.x

# Optional: Tuya IoT Cloud project (iot.tuya.com) — alternative way to get localKey
# TUYA_ACCESS_ID=
# TUYA_ACCESS_SECRET=
# TUYA_REGION=us
