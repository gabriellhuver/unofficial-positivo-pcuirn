# ── Required (cloud control: TV, AC, API, MCP) ─────────────────────────────
POSITIVO_EMAIL=you@example.com
POSITIVO_PASSWORD=your_password

# ── Optional server ──────────────────────────────────────────────────────────
# PORT=3000

# ── Optional: gateway details (only for local LAN / probe.js) ────────────────
# Run `node positivo.js` to discover these — NOT needed for cloud IR control.
# DEVICE_ID=your_gateway_device_id
# DEVICE_LOCAL_KEY=your_local_key
# DEVICE_IP=192.168.x.x

# ── Optional: behaviour flags ────────────────────────────────────────────────
# POSITIVO_FORCE_LOGIN=1          # ignore cached session, login again
# POSITIVO_REFRESH_DEVICES=1      # refetch device list instead of devices.json cache

# ── Optional: Tuya IoT Cloud (only if localKey missing) ─────────────────────
# See SETUP-TUYA.md
# TUYA_ACCESS_ID=
# TUYA_ACCESS_SECRET=
# TUYA_REGION=us
